{
    "global": {
        "spill_type": {
            "beam": {
                "plot_list": "plotlists/plot_list.csv",
                "tree_name": "h4",
                "detector_list": ["ecal", "mcp", "hodo", "bcp"],
                "option": null
            },
            "laser": {
                "plot_list": "plotlists/plot_list_laser.csv",
                "tree_name": "h4_laser",
                "detector_list": ["ecal", "mem"],
                "option": {
                    "ecal": {
                        "reco_conf": {
                            "do_5x5": false,
                        }
                    }
                }
            }
        }
    },

    "detectors": {
        "ecal": {
            "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
            "ch_map": "maps/tb_map.csv",
            "chid_vars_list": ["n_bcp","tt","ch_in_tt","module"],
            "decode": true,
            "to_be_inverted": false,
            "waves_branch": "xtal_sample",
            "generic_reco": true,
            "geo_needed": true,
            "reco_conf": {
                "signal_samples_pre_peak": 5,
                "signal_samples_post_peak": 10,
                "charge_zerosup_peak_threshold": 10,
                "seed_charge_threshold": 50,
                "do_5x5": true,
                "do_timing": true,
                "save_some_waves": true,
                "sampling_rate": 0.16
            }
        },

        "mem": {
            "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
            "ch_map": "maps/tb_map.csv",
            "chid_vars_list": ["n_bcp","tt","ch_in_tt"],
            "decode": true,
            "to_be_inverted": false,
            "waves_branch": "xtal_sample",
            "generic_reco": true,
            "geo_needed": true,
            "reco_conf": {
                "signal_samples_pre_peak": 5,
                "signal_samples_post_peak": 10,
                "charge_zerosup_peak_threshold": 10,
                "seed_charge_threshold": 50,
                "do_5x5": false,
                "do_timing": false,
                "save_some_waves": true,
                "sampling_rate": 0.08
            }
	},

        "mcp": {
            "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
            "ch_map": [1, 2, 3, 4],
            "decode": false,
            "to_be_inverted": true,
            "waves_branch": "dgtz_sample",
            "generic_reco": true,
            "geo_needed": false,
            "reco_conf": {
                "signal_samples_pre_peak": 6,
                "signal_samples_post_peak": 6,
                "charge_zerosup_peak_threshold": 60,
                "seed_charge_threshold": 0,
                "do_5x5": false,
                "do_timing": true,
                "save_some_waves": true,
                "sampling_rate": 1
            }
        },

        "hodo": {
            "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
            "ch_map": null,
            "decode": false,
            "to_be_inverted": false,
            "waves_branch": null,
            "generic_reco": false,
            "geo_needed": false,
            "reco_conf": {
                "signal_samples_pre_peak": 0,
                "signal_samples_post_peak": 0,
                "charge_zerosup_peak_threshold": 0,
                "seed_charge_threshold": 0,
                "do_5x5": false,
                "do_timing": false,
                "save_some_waves": true
            }
        },

        "bcp": {
            "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
            "ch_map": null,
            "decode": false,
            "to_be_inverted": false,
            "waves_branch": "bcp_clk",
            "generic_reco": false,
            "geo_needed": false,
            "reco_conf": {
                "signal_samples_pre_peak": 0,
                "signal_samples_post_peak": 0,
                "charge_zerosup_peak_threshold": 0,
                "seed_charge_threshold": 0,
                "do_5x5": false,
                "do_timing": false,
                "save_some_waves": true
            }
        }
    }
}
