{
    "global": {
        "spill_type": {
            "beam": {
                "plot_list": "plotlists/plot_list.csv",
                "tree_name": "h4",
                "detector_list": ["ecal", "mcp", "hodo", "bcp"],
                "option": null
            },
            "laser": {
                "plot_list": "plotlists/plot_list_laser.csv",
                "tree_name": "h4_laser",
                "detector_list": ["ecal", "mem"],
